#!/usr/bin/env python3
"""Auto-updater module"""

import json
import threading
from urllib.request import urlopen, Request

GITHUB_API = "https://api.github.com/repos/yourname/autosub/releases/latest"
CURRENT_VERSION = "1.0.0"


def check_updates_on_startup():
    """Background update check"""
    def check():
        try:
            req = Request(GITHUB_API, headers={"User-Agent": f"AutoSub/{CURRENT_VERSION}"})
            with urlopen(req, timeout=5) as response:
                release = json.loads(response.read().decode('utf-8'))
            
            latest = release['tag_name'].lstrip('v')
            
            # Simple version compare
            if latest > CURRENT_VERSION:
                print(f"\n🔄 Update available: v{latest} (you have v{CURRENT_VERSION})")
                print(f"   Download: {release['html_url']}\n")
        except:
            pass
    
    thread = threading.Thread(target=check, daemon=True)
    thread.start()
