```python
#!/usr/bin/env python3
"""
AutoSub Core - Main pipeline for subtitle generation
"""

import os
import re
import tempfile
import subprocess
from pathlib import Path
from typing import List, Dict, Optional
from dataclasses import dataclass
from datetime import timedelta

try:
    from faster_whisper import WhisperModel
    WHISPER_AVAILABLE = True
except ImportError:
    WHISPER_AVAILABLE = False

try:
    from deep_translator import GoogleTranslator
    TRANSLATION_AVAILABLE = True
except ImportError:
    TRANSLATION_AVAILABLE = False

try:
    import yt_dlp
    YTDLP_AVAILABLE = True
except ImportError:
    YTDLP_AVAILABLE = False


@dataclass
class SubtitleEntry:
    index: int
    start: float
    end: float
    text: str
    
    def to_srt_format(self) -> str:
        start_time = self._format_time(self.start)
        end_time = self._format_time(self.end)
        return f"{self.index}\n{start_time} --> {end_time}\n{self.text}\n"
    
    @staticmethod
    def _format_time(seconds: float) -> str:
        td = timedelta(seconds=seconds)
        hours, remainder = divmod(td.seconds, 3600)
        minutes, seconds = divmod(remainder, 60)
        milliseconds = int(td.microseconds / 1000)
        return f"{hours:02d}:{minutes:02d}:{seconds:02d},{milliseconds:03d}"


class VideoDownloader:
    def __init__(self, output_dir: str = "downloads"):
        self.output_dir = Path(output_dir)
        self.output_dir.mkdir(exist_ok=True)
    
    def download(self, url: str) -> Optional[Path]:
        if not YTDLP_AVAILABLE:
            print("Install yt-dlp: pip install yt-dlp")
            return None
        
        try:
            ydl_opts = {
                'format': 'best[height<=1080]/best',
                'outtmpl': str(self.output_dir / '%(title)s.%(ext)s'),
                'quiet': True,
                'no_warnings': True,
            }
            
            with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                info = ydl.extract_info(url, download=True)
                filename = ydl.prepare_filename(info)
                return Path(filename)
        except Exception as e:
            print(f"Download error: {e}")
            return None


class AudioExtractor:
    def extract(self, video_path: Path, output_path: Optional[Path] = None) -> Optional[Path]:
        if output_path is None:
            output_path = video_path.with_suffix('.wav')
        
        cmd = [
            'ffmpeg', '-y', '-i', str(video_path),
            '-vn', '-acodec', 'pcm_s16le', '-ar', '16000', '-ac', '1',
            str(output_path)
        ]
        
        try:
            subprocess.run(cmd, capture_output=True, check=True)
            return output_path
        except Exception as e:
            print(f"FFmpeg error: {e}")
            return None


class TranscriptionEngine:
    def __init__(self, model_size: str = "base", device: str = "auto"):
        self.model_size = model_size
        self.device = device
        self.model = None
        
    def load_model(self):
        if not WHISPER_AVAILABLE:
            raise RuntimeError("Install faster-whisper: pip install faster-whisper")
        
        compute_type = "float16" if self.device == "cuda" else "int8"
        self.model = WhisperModel(self.model_size, device=self.device, compute_type=compute_type)
        print(f"Loaded Whisper model: {self.model_size}")
    
    def transcribe(self, audio_path: Path) -> List[SubtitleEntry]:
        if self.model is None:
            self.load_model()
        
        segments, info = self.model.transcribe(
            str(audio_path),
            beam_size=5,
            best_of=5,
            condition_on_previous_text=True,
            vad_filter=True
        )
        
        print(f"Detected language: {info.language}")
        
        entries = []
        for i, segment in enumerate(segments, 1):
            entry = SubtitleEntry(
                index=i,
                start=segment.start,
                end=segment.end,
                text=segment.text.strip()
            )
            entries.append(entry)
        
        return entries


class TranslationEngine:
    def translate_entries(self, entries: List[SubtitleEntry], target_lang: str, source_lang: str = "auto") -> List[SubtitleEntry]:
        if not TRANSLATION_AVAILABLE:
            print("Install deep-translator: pip install deep-translator")
            return entries
        
        translated = []
        for entry in entries:
            try:
                translator = GoogleTranslator(source=source_lang, target=target_lang)
                translated_text = translator.translate(entry.text)
                
                new_entry = SubtitleEntry(
                    index=entry.index,
                    start=entry.start,
                    end=entry.end,
                    text=translated_text
                )
                translated.append(new_entry)
            except Exception as e:
                print(f"Translation error: {e}")
                translated.append(entry)
        
        return translated


class SubtitleWriter:
    def write_srt(self, entries: List[SubtitleEntry], output_path: Path):
        with open(output_path, 'w', encoding='utf-8') as f:
            for entry in entries:
                f.write(entry.to_srt_format() + '\n')
        print(f"Created: {output_path}")


class SubtitleBurner:
    def burn(self, video_path: Path, subtitle_path: Path, output_path: Path):
        cmd = [
            'ffmpeg', '-y', '-i', str(video_path),
            '-vf', f"subtitles={subtitle_path}:force_style='FontSize=24'",
            '-c:a', 'copy', str(output_path)
        ]
        
        try:
            subprocess.run(cmd, capture_output=True, check=True)
            print(f"Created: {output_path}")
            return output_path
        except Exception as e:
            print(f"Burn error: {e}")
            return None


class AutoSubPipeline:
    def __init__(self, model_size: str = "base", output_dir: str = "output"):
        self.downloader = VideoDownloader()
        self.audio_extractor = AudioExtractor()
        self.transcriber = TranscriptionEngine(model_size)
        self.translator = TranslationEngine()
        self.writer = SubtitleWriter()
        self.burner = SubtitleBurner()
        self.output_dir = Path(output_dir)
        self.output_dir.mkdir(exist_ok=True)
        
    def process(self, source: str, target_languages: List[str] = None, burn_subtitles: bool = False, keep_audio: bool = False):
        target_languages = target_languages or ['en']
        results = {}
        
        # Get video
        if source.startswith(('http://', 'https://')):
            print(f"Downloading: {source}")
            video_path = self.downloader.download(source)
        else:
            video_path = Path(source)
        
        if not video_path or not video_path.exists():
            raise RuntimeError("Failed to get video")
        
        print(f"Processing: {video_path.name}")
        
        # Extract audio
        audio_path = self.audio_extractor.extract(video_path)
        if not audio_path:
            raise RuntimeError("Failed to extract audio")
        
        # Transcribe
        print("Transcribing...")
        source_entries = self.transcriber.transcribe(audio_path)
        
        # Generate subtitles
        base_name = video_path.stem
        
        for lang in target_languages:
            if lang == 'en':
                entries = source_entries
            else:
                print(f"Translating to {lang}...")
                entries = self.translator.translate_entries(source_entries, lang)
            
            srt_path = self.output_dir / f"{base_name}.{lang}.srt"
            self.writer.write_srt(entries, srt_path)
            results[f"srt_{lang}"] = srt_path
        
        # Burn subtitles
        if burn_subtitles:
            for lang in target_languages:
                srt_path = results.get(f"srt_{lang}")
                if srt_path:
                    output_video = self.output_dir / f"{base_name}.{lang}.mp4"
                    self.burner.burn(video_path, srt_path, output_video)
                    results[f"video_{lang}"] = output_video
        
        # Cleanup
        if not keep_audio and audio_path.exists():
            audio_path.unlink()
        
        print(f"\nDone! Files in: {self.output_dir}")
        return results
```

## **`autosub/cli.py`**
```python
#!/usr/bin/env python3
"""Command line interface"""

import argparse
import sys
from pathlib import Path

from .core import AutoSubPipeline


def main():
    parser = argparse.ArgumentParser(description='AutoSub - Automatic Subtitle Generator')
    parser.add_argument('source', help='Video file or URL')
    parser.add_argument('--langs', nargs='+', default=['en'], help='Target languages')
    parser.add_argument('--model', default='base', choices=['tiny', 'base', 'small', 'medium', 'large'])
    parser.add_argument('--burn', action='store_true', help='Burn subtitles into video')
    parser.add_argument('--output', default='output', help='Output directory')
    
    args = parser.parse_args()
    
    # Ensure English is included
    langs = list(set(args.langs + ['en']))
    
    pipeline = AutoSubPipeline(model_size=args.model, output_dir=args.output)
    
    results = pipeline.process(
        source=args.source,
        target_languages=langs,
        burn_subtitles=args.burn
    )
    
    print("\nGenerated files:")
    for key, path in results.items():
        print(f"  {key}: {path}")


if __name__ == '__main__':
    main()
