#!/usr/bin/env python3
"""Build standalone executables"""

import shutil
import subprocess
from pathlib import Path


def clean():
    for d in ['build', 'dist', '__pycache__']:
        if Path(d).exists():
            shutil.rmtree(d)


def build():
    clean()
    
    # Build CLI
    subprocess.run([
        'pyinstaller',
        '--name=autosub',
        '--onefile',
        '--console',
        'autosub/cli.py'
    ], check=True)
    
    # Build Web
    subprocess.run([
        'pyinstaller',
        '--name=AutoSub-Web',
        '--onefile',
        'autosub/web.py'
    ], check=True)
    
    print("✅ Built: dist/autosub, dist/AutoSub-Web")


if __name__ == '__main__':
    build()
